# ─── ObraFlow API — environment variables ───────────────────────────
# Copy to .env and fill in. In Railway these are set as service variables.

# Runtime
NODE_ENV=development
PORT=3000

# Database (Prisma). Postgres in prod, e.g. postgresql://user:pass@host:5432/obraflow
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/obraflow

# Auth / JWT
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-too-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173

# Frontend / links in emails
APP_URL=http://localhost:5173

# Mail (SMTP). If SMTP_HOST is unset in dev, mailer falls back to jsonTransport.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ObraFlow <no-reply@obraflow.app>"

# Billing (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
